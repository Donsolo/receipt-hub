<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#0B1220</item>
        <item name="colorPrimaryDark">#0B1220</item>
        <item name="colorAccent">#2563EB</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#0B1220</item>
        <item name="android:navigationBarColor">#0B1220</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="AppTheme" />
    <style name="AppTheme.NoActionBar.LaunchTheme" parent="AppTheme.NoActionBar">
        <item name="android:windowSplashScreenBackground">#0B1220</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
